# Copy to `relay.env` (gitignored) and fill. Generate each token ONCE on your Mac (it has a
# browser); the container never runs an interactive login. See NAS_DEPLOYMENT.md §A3.

# claude (Max subscription): run `claude setup-token` on your Mac -> long-lived (~1yr) token
CLAUDE_CODE_OAUTH_TOKEN=

# gh + copilot (both use this): a GitHub PAT with "Copilot Requests" + repo scope
GH_TOKEN=

# codex: either a ChatGPT device login (mount ~/.codex via compose) OR a pay-per-token key
OPENAI_API_KEY=

# agy / Gemini: a Gemini API key OR mount agy's creds dir via compose
GEMINI_API_KEY=

# ttyd web terminal password (username is set to "relay" in compose)
TTYD_PASS=

# git authorship for the control plane's commits/pushes
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=
GIT_COMMITTER_NAME=
GIT_COMMITTER_EMAIL=

# board (personal profile): the repo whose issues relay watches
GITHUB_REPO=ManikantaR/smartocrprocess

# notifications (personal profile): Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
